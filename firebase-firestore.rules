rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAppVionAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          "appvionstudio@gmail.com",
          "ayyazali.sajjadali@gmail.com"
        ];
    }

    match /siteContent/home {
      allow read: if true;
      allow write: if isAppVionAdmin();
    }

    match /projectBriefs/{briefId} {
      allow create: if request.resource.data.keys().hasOnly([
          "name",
          "email",
          "type",
          "timeline",
          "message",
          "source",
          "userAgent",
          "status",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() > 4
        && request.resource.data.email.size() <= 180
        && request.resource.data.type is string
        && request.resource.data.type.size() > 0
        && request.resource.data.type.size() <= 80
        && request.resource.data.timeline is string
        && request.resource.data.timeline.size() > 0
        && request.resource.data.timeline.size() <= 80
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 4000
        && request.resource.data.source == "website-contact-form"
        && request.resource.data.status == "new"
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if isAppVionAdmin();
    }

    match /contactEvents/{eventId} {
      allow create: if request.resource.data.keys().hasOnly([
          "route",
          "label",
          "href",
          "source",
          "page",
          "userAgent",
          "status",
          "createdAt"
        ])
        && request.resource.data.route is string
        && request.resource.data.route.size() > 0
        && request.resource.data.route.size() <= 80
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 140
        && request.resource.data.href is string
        && request.resource.data.href.size() > 0
        && request.resource.data.href.size() <= 500
        && request.resource.data.source == "website-contact-click"
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 120
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 600
        && request.resource.data.status == "new"
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if isAppVionAdmin();
    }
  }
}
