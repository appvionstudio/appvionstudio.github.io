{
  "hosting": {
    "public": ".",
    "ignore": [
      ".git",
      ".github",
      ".firebaserc",
      "firebase.json",
      "firebase-firestore.rules",
      "FIREBASE-SETUP.md"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firebase-firestore.rules"
  }
}
